# Alibaba Cloud OSS
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
REGION=your_oss_region
BUCKET_NAME=your_bucket_name

# Alibaba Cloud Tablestore
TABLESTORE_ACCESS_KEY_ID=your_tablestore_access_key_id
TABLESTORE_ACCESS_KEY_SECRET=your_tablestore_access_key_secret
TABLE_INSTANCE_NAME=your_table_instance_name
TABLE_ENDPOINT=your_table_endpoint
ENV_TABLE_NAME=env
ENV_MEASURE_NAME=device_env
COLONY_TABLE_NAME=colony
COLONY_MEASURE_NAME=device_colony

# MQTT Broker
USERNAME=your_mqtt_username
PASSWORD=your_mqtt_password
PORT=tcp://localhost:1883

# Web Server
WEB_PORT=8182

# Bailian AI
DASHSCOPE_API_KEY=your_dashscope_api_key
MODEL_NAME=qwen3.6-plus

# Email Alerts (optional)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SRC_EMAIL=sender@example.com
DEST_EMAIL=recipient@example.com
AUTHCODE=your_smtp_auth_code
